{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "roots": ["<rootDir>/tests"],
  "testMatch": ["**/*.test.ts"],
  "transform": {
    "^.+\\.ts$": ["ts-jest", {
      "tsconfig": {
        "strict": true,
        "esModuleInterop": true,
        "module": "CommonJS"
      }
    }]
  },
  "globalSetup": "<rootDir>/tests/globalSetup.ts",
  "globalTeardown": "<rootDir>/tests/globalTeardown.ts",
  "testTimeout": 60000,
  "collectCoverageFrom": [
    "src/**/*.ts",
    "!src/server.ts",
    "!src/seed/**"
  ],
  "coverageThreshold": {
    "global": {
      "lines": 70
    }
  },
  "verbose": true
}
